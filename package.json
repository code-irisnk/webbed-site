{
  "name": "webbed-site",
  "version": "2.0.1-ssg",
  "scripts": {
    "build": "node src/generate-sitemap.mjs && node src/generate-feed.mjs && ng build --configuration production",
    "dev": "ng serve --configuration development",
    "deploy": "tsc -p tsconfig.deploy.json && node dist/deploy/deploy.js",
    "format:ts": "eslint --ext .ts,.tsx,.js,.jsx,.html --fix .",
    "format:css": "prettier --write '**/*.{css,scss,html,ts}'",
    "format": "pnpm run format:ts && pnpm run format:css",
    "serve:ssr:webbed-site": "node dist/webbed-site/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.13",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/material": "^21.2.13",
    "@angular/platform-browser": "^21.2.15",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@angular/platform-server": "^21.2.14",
    "@angular/router": "^21.2.14",
    "@angular/ssr": "^21.2.12",
    "@catppuccin/palette": "^1.8.0",
    "express": "^5.2.1",
    "feed": "^5.2.1",
    "rxjs": "~7.8.2",
    "sanitize-html": "^2.17.4",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "@eslint/js": "^10.0.1",
    "@types/browser-sync": "2.29.1",
    "@types/express": "^5.0.6",
    "@types/jasmine": "~6.0.0",
    "@types/karma": "~6.3.9",
    "@types/karma-chrome-launcher": "~3.1.4",
    "@types/karma-coverage": "~2.0.3",
    "@types/karma-jasmine": "~4.0.5",
    "@types/karma-jasmine-html-reporter": "~1.7.3",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "angular-eslint": "^21.4.0",
    "baseline-browser-mapping": "^2.10.31",
    "browser-sync": "^3.0.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine-core": "~6.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "packageManager": "pnpm@11.5.0"
}
